# ── Server ────────────────────────────────────────────────────────────────────

# TCP port the Express server listens on.
# Render sets this automatically in production — leave blank or omit.
PORT=3001

# ── GitHub integration (optional) ─────────────────────────────────────────────
# Enables creating GitHub issues from failing test-run results.
# Both values must be set for the feature to work. If omitted, it is silently
# disabled — the app works normally without them.

# Personal access token with "repo" scope.
# Create one at https://github.com/settings/tokens
GITHUB_TOKEN=

# Repository to file issues against — "owner/repo" format.
GITHUB_REPO=

# ── CI / GitHub Actions only ──────────────────────────────────────────────────
# Used by .github/workflows/pr-review.yml to post review comments to Discord.
# Not required to run the app locally or in production.
DISCORD_BOT_TOKEN=

# ── Flaky Test Tracker ────────────────────────────────────────────────────────
# Discord channel ID to receive new-flake alerts from the PostToolUse hook.
DISCORD_FLAKY_CHANNEL_ID=
